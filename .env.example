# ── AI Provider ──────────────────────────────────────────────────
# Configure ONE of the two providers below.

# Option 1: Anthropic API (simplest — just needs an API key)
# ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Google Cloud Vertex AI
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# CLOUD_ML_REGION=us-east5
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── App ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string

# Model (optional — also configurable in Settings > Pipeline Run)
# Vertex AI format: claude-sonnet-4-6@default
# Anthropic API format: claude-sonnet-4-6-latest
CLAUDE_MODEL=claude-sonnet-4-6@default

# Optional
PORT=3001
NODE_ENV=development
CRON_ENABLED=true
CRON_SCHEDULE=0 14 * * 1
